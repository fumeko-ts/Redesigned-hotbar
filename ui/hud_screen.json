{
  "hotbar_chooser": {
    "type": "panel",
    "size": ["100%c", 26],
    "controls": [
      {
        "custom_hotbar": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": ["100%c", 26],
          "offset": [-4, 1],
          "anchor_from": "bottom_middle",
          "anchor_to": "bottom_middle",
          "$hotbar_collection_name|default": "hotbar_items",
          "controls": [
            {
              "left_stack_and_spacer_1": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": [25, 26],
                "controls": [
                  {
                    "left_stack": {
                      "type": "stack_panel",
                      "orientation": "vertical",
                      "size": [23, 26],
                      "controls": [
                        { "filler_1": { "type": "panel", "size": [23, "fill"] } },
                        { "left@custom_hotbars.inventory_button": {} },
                        { "filler_2": { "type": "panel", "size": [23, "fill"] } }
                      ]
                    }
                  },
                  { "spacer_1": { "type": "panel", "size": [2, 26] } }
                ],
                "bindings": [
                  {
                    "binding_name": "#hotbar_elipses_left_visible",
                    "binding_name_override": "#visible",
                    "binding_type": "global"
                  }
                ]
              }
            },
            {
              "start_cap@custom_hotbars.section_template": {
                "uv": [0, 0],
                "uv_size": [2, 26],
                "size": [2, 26],
                "controls": []
              }
            },
            {
              "custom_gui_hotbar_grid": {
                "size": [180, 26],
                "type": "grid",
                "grid_item_template": "custom_hotbars.section",
                "grid_dimensions": [9, 1],
                "collection_name": "$hotbar_collection_name"
              }
            },
            {
              "end_cap@custom_hotbars.section_template": {
                "uv": [182, 0],
                "uv_size": [2, 26],
                "size": [2, 26],
                "controls": []
              }
            },
            {
              "right_stack_and_spacer_2": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": [25, 26],
                "controls": [
                  { "spacer_2": { "type": "panel", "size": [2, 26] } },
                  {
                    "right_stack": {
                      "type": "stack_panel",
                      "orientation": "vertical",
                      "size": [23, 26],
                      "controls": [
                        { "filler_3": { "type": "panel", "size": [23, "fill"] } },
                        { "right@custom_hotbars.inventory_button": {} },
                        { "filler_4": { "type": "panel", "size": [23, "fill"] } }
                      ]
                    }
                  }
                ],
                "bindings": [
                  {
                    "binding_name": "#hotbar_elipses_right_visible",
                    "binding_name_override": "#visible",
                    "binding_type": "global"
                  }
                ]
              }
            }
          ],
          "bindings": [
            {
              "binding_name": "#hotbar_visible",
              "binding_name_override": "#visible"
            }
          ]
        }
      }
    ]
  },
  //ngl no clue what the below actualy offsets but seems to work for me so im just going to roll with it
  //if eanyone knows a better way feel free to inform me i would love to know
  "root_panel/exp_rend_resizable": { "offset": [0, -17] },
  "root_panel/exp_rend": { "offset": [0, -17] },
  "root_panel/centered_gui_elements_at_bottom_middle": { "offset": [0, -3] }
  // ,
  // "root_panel/centered_gui_elements_at_bottom_middle_touch": { "offset": [0, -3] }
}
